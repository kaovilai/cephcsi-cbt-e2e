 	if err := iterator.GetSnapshotMetadata(ctx, args); err != nil {
 		return nil, fmt.Errorf("GetMetadataDelta %s -> %s: %w", prevSnapshotName, snapshotName, err)
 	}
-
 	return result, nil
 }
 
