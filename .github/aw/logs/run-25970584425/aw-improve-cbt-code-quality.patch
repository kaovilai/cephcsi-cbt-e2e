From fbe49ada5344e0b3856d77857e71173f63b620f5 Mon Sep 17 00:00:00 2001
From: "github-actions[bot]" <github-actions[bot]@users.noreply.github.com>
Date: Sat, 16 May 2026 19:21:56 +0000
Subject: [PATCH] pkg/cbt: reduce duplication with newResultAndArgs helper,
 remove debug logs
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Extract repeated boilerplate (result+emitter+base args creation) into a
newResultAndArgs method on Client. All five public methods now call it
and set only their snapshot-specific fields.

Also remove debug log.Printf statements from collectingEmitter and
GetAllocatedBlocks that were left over from development — they pollute
test output and were inconsistently applied to only one of five methods.
Removing the log import as it is no longer used.

Co-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>
---
 pkg/cbt/cbt.go | 107 ++++++++++++++++---------------------------------
 1 file changed, 34 insertions(+), 73 deletions(-)

diff --git a/pkg/cbt/cbt.go b/pkg/cbt/cbt.go
index 0aa5c06..0907df6 100644
--- a/pkg/cbt/cbt.go
+++ b/pkg/cbt/cbt.go
@@ -4,7 +4,6 @@ package cbt
 import (
 	"context"
 	"fmt"
-	"log"
 
 	"github.com/kubernetes-csi/external-snapshot-metadata/pkg/api"
 	"github.com/kubernetes-csi/external-snapshot-metadata/pkg/iterator"
@@ -57,14 +56,11 @@ type collectingEmitter struct {
 }
 
 func (e *collectingEmitter) SnapshotMetadataIteratorRecord(recordNum int, metadata iterator.IteratorMetadata) error {
-	log.Printf("DEBUG emitter Record #%d: BlockMetadataType=%v VolumeCapacityBytes=%d numBlocks=%d",
-		recordNum, metadata.BlockMetadataType, metadata.VolumeCapacityBytes, len(metadata.BlockMetadata))
 	if len(e.result.Blocks) == 0 {
 		e.result.BlockMetadataType = metadata.BlockMetadataType
 	}
 	e.result.VolumeCapacityBytes = metadata.VolumeCapacityBytes
-	for i, bm := range metadata.BlockMetadata {
-		log.Printf("DEBUG emitter Record #%d block[%d]: offset=%d size=%d", recordNum, i, bm.ByteOffset, bm.SizeBytes)
+	for _, bm := range metadata.BlockMetadata {
 		e.result.Blocks = append(e.result.Blocks, BlockMetadata{
 			ByteOffset: bm.ByteOffset,
 			SizeBytes:  bm.SizeBytes,
@@ -73,97 +69,69 @@ func (e *collectingEmitter) SnapshotMetadataIteratorRecord(recordNum int, metada
 	return nil
 }
 
-func (e *collectingEmitter) SnapshotMetadataIteratorDone(recordNum int) error {
-	log.Printf("DEBUG emitter Done: recordNum=%d totalBlocks=%d volCapacity=%d",
-		recordNum, len(e.result.Blocks), e.result.VolumeCapacityBytes)
+func (e *collectingEmitter) SnapshotMetadataIteratorDone(_ int) error {
 	return nil
 }
 
-// GetAllocatedBlocks returns all allocated blocks for a snapshot.
-func (c *Client) GetAllocatedBlocks(ctx context.Context, snapshotName string) (*MetadataResult, error) {
+// newResultAndArgs creates a MetadataResult and the base iterator.Args pre-populated
+// with client fields common to every CBT call. Callers set snapshot-specific fields.
+func (c *Client) newResultAndArgs() (*MetadataResult, iterator.Args) {
 	result := &MetadataResult{}
 	emitter := &collectingEmitter{result: result}
-
 	args := iterator.Args{
-		Clients:      c.clients,
-		Emitter:      emitter,
-		Namespace:    c.namespace,
-		SnapshotName: snapshotName,
-		SANamespace:  c.saNamespace,
-		SAName:       c.saName,
+		Clients:     c.clients,
+		Emitter:     emitter,
+		Namespace:   c.namespace,
+		SANamespace: c.saNamespace,
+		SAName:      c.saName,
 	}
+	return result, args
+}
+
+// GetAllocatedBlocks returns all allocated blocks for a snapshot.
+func (c *Client) GetAllocatedBlocks(ctx context.Context, snapshotName string) (*MetadataResult, error) {
+	result, args := c.newResultAndArgs()
+	args.SnapshotName = snapshotName
 
-	log.Printf("DEBUG GetAllocatedBlocks: calling iterator.GetSnapshotMetadata(namespace=%s, snapshot=%s, saNamespace=%s, saName=%s)",
-		c.namespace, snapshotName, c.saNamespace, c.saName)
 	if err := iterator.GetSnapshotMetadata(ctx, args); err != nil {
 		return nil, fmt.Errorf("GetMetadataAllocated for %s: %w", snapshotName, err)
 	}
-
-	log.Printf("DEBUG GetAllocatedBlocks: result blocks=%d volCapacity=%d metadataType=%v",
-		len(result.Blocks), result.VolumeCapacityBytes, result.BlockMetadataType)
 	return result, nil
 }
 
 // GetChangedBlocks returns blocks changed between two snapshots.
 // prevSnapshotName is the base (older) snapshot, snapshotName is the target (newer).
 func (c *Client) GetChangedBlocks(ctx context.Context, prevSnapshotName, snapshotName string) (*MetadataResult, error) {
-	result := &MetadataResult{}
-	emitter := &collectingEmitter{result: result}
-
-	args := iterator.Args{
-		Clients:          c.clients,
-		Emitter:          emitter,
-		Namespace:        c.namespace,
-		SnapshotName:     snapshotName,
-		PrevSnapshotName: prevSnapshotName,
-		SANamespace:      c.saNamespace,
-		SAName:           c.saName,
-	}
+	result, args := c.newResultAndArgs()
+	args.SnapshotName = snapshotName
